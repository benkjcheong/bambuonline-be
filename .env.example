# Bambu printer
PRINTER_IP=YOUR_PRINTER_IP
PRINTER_SERIAL=YOUR_PRINTER_SERIAL
ACCESS_CODE=YOUR_BAMBU_ACCESS_CODE

# Telegram alerts
TG_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TG_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Slicer (Bambu Studio CLI) — defaults work for a stock macOS install + A1 mini.
# The filament dropdown is sourced from your CUSTOM presets in SLICER_USER_PROFILE_DIR
# (stock Bambu/eSun profiles are hidden); SLICER_FILAMENT must name one of them.
#SLICER_BIN=/Applications/BambuStudio.app/Contents/MacOS/BambuStudio
#SLICER_PROFILE_DIR=/Applications/BambuStudio.app/Contents/Resources/profiles/BBL
#SLICER_USER_PROFILE_DIR=~/Library/Application Support/BambuStudio/user
# Filament presets vendored in the repo (presets/filament/*.json) — authoritative,
# override same-named user presets. Lets the app work without a local Studio install.
#SLICER_REPO_PRESET_DIR=./presets
#SLICER_MODEL_NAME=Bambu Lab A1 mini
#SLICER_MODEL_CODE=A1M
#SLICER_MACHINE=Bambu Lab A1 mini 0.4 nozzle
#SLICER_PROCESS=0.20mm Standard @BBL A1M
#SLICER_FILAMENT=Alt Tab PLA Basic @Bambu Lab A1 mini 0.4 nozzle
#SLICER_TIMEOUT_SEC=300

# AI spaghetti detection - same as Obico
SPAGHETTI_INTERVAL_SEC=30 #Camera FPS
SPAGHETTI_DETECTION_THRESHOLD=0.08 #Raw confidence threshold
SPAGHETTI_SENSITIVITY=1.0 #Alarm sensitivity (0.8 low, 1.0 medium, 1.2 high)
SPAGHETTI_THRESHOLD_LOW=0.38 #Min risk to alarm
SPAGHETTI_THRESHOLD_HIGH=0.78 #Always-alarm ceiling
SPAGHETTI_ROLLING_MEAN_SHORT_MULTIPLE=3.8 #Spike vs baseline multiplier